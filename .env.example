# =============================================================================
# Learn AI — Data Engineering Track
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load it in your shell:
#   source .env
#
# NEVER commit your .env file. It's already in .gitignore.
# =============================================================================

# --- GCP ---
# Your GCP project ID (e.g., "learn-ai-pipeline-12345")
# Find it: gcloud config get-value project
GCP_PROJECT_ID=

# GCP region for resources (default is fine for most participants)
GCP_REGION=us-central1

# --- Anthropic API (Session 4+) ---
# Get your key: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=

# --- Optional ---
# OpenWeather API key (free tier: https://openweathermap.org/api)
# Only needed if your capstone uses weather data
# OPENWEATHER_API_KEY=
